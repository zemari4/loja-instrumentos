# ── Django ────────────────────────────────────────
DJANGO_ENV=dev
DEBUG=True
SECRET_KEY='change-me-use-a-long-random-string'
PRIMARY_HOST=
PRIMARY_ORIGIN=

# ── Database ──────────────────────────────────────
# Se omitido, usa SQLite local
DATABASE_URL=postgresql://user:password@localhost:5432/musicmais

# ── Cache / Redis ─────────────────────────────────
DISABLE_CACHE=False
DISABLE_REDIS=False
CACHE_LOCATION=redis://localhost:6379/0
REDIS_PASSWORD=

# ── Celery ────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage S3/MinIO ──────────────────────────────
ENABLE_S3_STORAGE=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=
AWS_S3_SIGNATURE_VERSION=
AWS_STORAGE_BUCKET_NAME=

# Bucket privado (NF-e, DANFE)
PRIVATE_AWS_ACCESS_KEY_ID=
PRIVATE_AWS_SECRET_ACCESS_KEY=
PRIVATE_AWS_STORAGE_BUCKET_NAME=

# ── Sentry ────────────────────────────────────────
SENTRY_SDK=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=dev

# ── Encryption ────────────────────────────────────
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# ── Email ─────────────────────────────────────────
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Pagamentos ────────────────────────────────────
PAGARME_API_KEY=

# ── Frete ─────────────────────────────────────────
MELHOR_ENVIO_TOKEN=

# ── Fiscal ────────────────────────────────────────
FOCUS_NFE_TOKEN=

# ── Analytics ─────────────────────────────────────
GA_ID_INTERNAL=
GA_ID_EXTERNAL=
GTM_ID_INTERNAL=
GTM_ID_EXTERNAL=
CLARITY_ID_INTERNAL=
CLARITY_ID_EXTERNAL=

# ── AI (Copilot + Blog) ────────────────────────────
AI_GENERATION_ENABLED=False
ANTHROPIC_API_KEY=

# ── Dev tools ─────────────────────────────────────
INTERNAL_IP=127.0.0.1
DISABLE_DEBUG_TOOLBAR=False
